# Copy to ".env" and fill in your Supabase project values.
# Find these in the Supabase dashboard → Project Settings → API.
# Leave BOTH unset to run the app in in-memory demo mode (no backend).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Invite-only: set to "true" to hide self-signup + Google from the login screen,
# so the app shows email/password sign-in only. The REAL enforcement is the
# "Disable signup" toggle in Supabase (Authentication → Sign In / Providers).
VITE_DISABLE_SIGNUP=

# Billing: leave blank/false during free testing — no trial countdown, no
# paywall, everyone has full access after signing up. Set to "true" to turn the
# 7-day trial + Stripe paywall back on.
VITE_BILLING_ENABLED=
